---
import TagList from "./TagList.astro";
interface Props {
  name: string;
  description: string;
  tags: string[];
  link: string;
}

const { name, description, tags, link } = Astro.props;
---

<div class="group/project-link">
  <div class="flex gap-2 items-center transition-colors duration-300">
    <a draggable="false" href={link} class="text-foreground">
      <div
        class="flex flex-wrap items-center gap-2 group-hover/project-link:text-accent"
      >
        <span class="text-muted/70 group-hover/project-link:text-accent">
          @
        </span>

        <span
          class="font-medium mr-2 group-hover/project-link:underline underline-offset-2"
        >
          {name}
        </span>
      </div>
    </a>
    <TagList tags={tags} />
  </div>

  <p
    class="mt-2 pl-5 text-muted/80 group-hover/project-link:text-muted cursor-default"
  >
    └─ {description}
  </p>
</div>
