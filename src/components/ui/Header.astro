---
// Normalize pathname by removing the trailing slash (except for the root "/")
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const links = [
  { href: "/", label: "~/home" },
  { href: "/projects", label: "~/projects" },
  { href: "/writings", label: "~/writings" },
  { href: "/gallery", label: "~/gallery" },
  { href: "/about", label: "~/about" },
];
---

<header
  class="p-4 md:px-12 lg:px-16
       fixed top-0 left-0 right-0 z-50
       bg-background/80
       backdrop-blur-lg
       border-b border-border
       shadow-sm shadow-black/40"
>
  <nav class="flex items-center justify-between">
    <div class="group h-6 tracking-tight">
      <a
        href="/"
        class="text-foreground/90 transition-all dark:group-hover:drop-shadow-[0_0_10px_rgba(255,255,255,0.6)] group-hover:drop-shadow-[0_0_10px_rgba(0,0,0,0.3)]"
      >
        gourav

        <span
          class="text-foreground/40 transition-all dark:group-hover:text-zinc-100 group-hover:text-zinc-900"
        >
          @arch
        </span>
      </a>
    </div>

    <ul
      class="hidden md:flex text-foreground/50"
      style="gap: clamp(0.5rem, 3vw, 3rem);
      font-size: clamp(0.9rem, 0.5rem + 0.5vw, 1.2rem);"
    >
      {
        links.map((link) => {
          const isActiveLink =
            link.href === "/"
              ? pathname === "/"
              : pathname.startsWith(link.href);

          return (
            <li
              class={`hover:scale-105 hover:text-foreground/90 transition-all duration-300 ease-out ${
                isActiveLink
                  ? "text-foreground/90 border-b-2 border-foreground/60"
                  : ""
              }`}
            >
              <a href={link.href} class="px-1 py-3">
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>
    <button
      id="menu-toggle"
      class="flex justify-center rounded-lg border border-border h-8 w-8 bg-background/40 md:hidden text-2xl text-foreground/60 hover:text-foreground/90 hover:scale-105 transition-all duration-300 cursor-pointer"
    >
      <span id="menu-icon">☰</span>
    </button>

    <button
      id="theme-toggle"
      aria-label="Toggle theme"
      class="inline-block rounded-lg border border-border px-2.5 py-0.5 bg-background/40 text-xl text-foreground/60 hover:text-foreground/90 hover:scale-110 transition-all cursor-pointer"
    >
      ☾
    </button>
  </nav>

  <div
    id="mobile-menu"
    class="hidden md:hidden mt-4 border-t border-border pt-4 z-100"
  >
    <ul class="flex flex-col gap-3 text-foreground/80">
      {
        links.map((link) => {
          const isActiveLink =
            link.href === "/"
              ? pathname === "/"
              : pathname.startsWith(link.href);

          return (
            <li>
              <a href={link.href} class={isActiveLink ? "text-foreground" : ""}>
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</header>

<div
  id="menu-overlay"
  class="hidden fixed inset-0 md:hidden bg-background/0 backdrop-blur-sm shadow-sm shadow-black/90 h-screen w-screen z-40"
>
</div>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const menuOverlay = document.getElementById("menu-overlay");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");

  function toggleMenu() {
    mobileMenu?.classList.toggle("hidden");
    menuOverlay?.classList.toggle("hidden");

    if (menuIcon) {
      menuIcon.textContent = mobileMenu?.classList.contains("hidden")
        ? "☰"
        : "✕";
    }
  }

  menuToggle?.addEventListener("click", toggleMenu);
  menuOverlay?.addEventListener("click", toggleMenu);

  document.addEventListener("astro:page-load", () => {
    const themeToggle = document.getElementById("theme-toggle");

    function updateThemeIcon() {
      if (themeToggle) {
        themeToggle.textContent = document.documentElement.classList.contains(
          "dark",
        )
          ? "☼"
          : "☾";
      }
    }

    updateThemeIcon();

    themeToggle?.addEventListener("click", () => {
      document.documentElement.classList.toggle("dark");
      const isDark = document.documentElement.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
      updateThemeIcon();
    });
  });
</script>
