---
import BrandLogo from "./BrandLogo.astro";
import DesktopNav from "./DesktopNav.astro";
import ThemeToggle from "./ThemeToggle.astro";

// Normalize pathname by removing the trailing slash (except for the root "/")
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const links = [
  { href: "/", label: "home" },
  { href: "/projects", label: "projects" },
  { href: "/logs", label: "logs" },
  { href: "/music", label: "music" },
];
---

<header
  class="p-4 md:px-12 lg:px-16
       fixed top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl z-50"
>
  <!-- Faded background and bottom shadow -->
  <div
    class="absolute inset-0 bg-background/80 backdrop-blur-lg border-b border-border shadow-[0_12px_40px_-12px_rgba(0,0,0,0.2)] dark:shadow-[0_12px_40px_-12px_rgba(0,0,0,0.5)] [mask-image:linear-gradient(to_right,transparent_0%,black_10%,black_90%,transparent_100%)] -z-10 pointer-events-none"
  >
  </div>

  <nav class="flex items-center relative z-10">
    <BrandLogo />

    <div class="flex items-center gap-8 ml-auto">
      <DesktopNav links={links} pathname={pathname} />
      
      <div class="flex gap-2">
        <ThemeToggle />
        <button
          id="menu-toggle"
          class="md:hidden inline-block rounded-lg border border-border px-2 py-0.5 bg-background/40 text-xl text-foreground/60 hover:text-foreground/90 hover:scale-110 transition-all cursor-pointer"
        >
          <span id="menu-icon">☰</span>
        </button>
      </div>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="hidden md:hidden mt-4 border-t border-border pt-4 z-100"
  >
    <ul class="flex flex-col gap-3 text-foreground/80">
      {
        links.map((link) => {
          const isActiveLink =
            link.href === "/"
              ? pathname === "/"
              : pathname.startsWith(link.href);

          return (
            <li class="flex justify-end">
              <a href={link.href} class={isActiveLink ? "text-foreground" : ""}>
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</header>

<div
  id="menu-overlay"
  class="hidden fixed inset-0 md:hidden bg-background/0 backdrop-blur-sm shadow-sm shadow-black/90 h-screen w-screen z-40"
>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const menuToggle = document.getElementById("menu-toggle");
    const menuOverlay = document.getElementById("menu-overlay");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuIcon = document.getElementById("menu-icon");

    function toggleMenu() {
      mobileMenu?.classList.toggle("hidden");
      menuOverlay?.classList.toggle("hidden");

      if (menuIcon) {
        menuIcon.textContent = mobileMenu?.classList.contains("hidden")
          ? "☰"
          : "✕";
      }
    }

    if (menuToggle && menuOverlay) {
      menuToggle.onclick = toggleMenu;
      menuOverlay.onclick = toggleMenu;
    }
    menuOverlay?.addEventListener("click", toggleMenu);
  });
</script>
