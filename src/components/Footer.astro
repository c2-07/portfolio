---
import { Image } from "astro:assets";
import AstroSVG from "../assets/icons/astro.svg";
import TailwindSVG from "../assets/icons/tailwind.svg";
---

<footer
  class="mt-auto flex items-center gap-3 text-foreground/70
         text-[12px]
         md:text-sm
         py-2 px-4 md:px-12 lg:px-16
         bg-background/90
         border-t border-border"
>
  <span>made with</span>❤
  <span class="ml-auto flex items-center gap-2">
    built with
    <span class="hidden sm:inline"> [ astro · tailwind ] </span>
    <Image
      src={AstroSVG}
      alt="astro"
      class="h-4 w-4 brightness-0 dark:invert sm:hidden"
    />
    <Image
      src={TailwindSVG}
      alt="tailwind"
      class="h-4 w-4 brightness-0 dark:invert sm:hidden"
    />
  </span>
</footer>
