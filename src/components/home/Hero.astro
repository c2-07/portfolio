---
import UserAvatar from "../../assets/images/cat.jpg";
import { Image } from "astro:assets";
---

<section
  class="grid grid-cols-1 md:grid-cols-[0.9fr_2.1fr] items-center gap-8 min-h-[clamp(22rem,50vh,36rem)]"
>
  <div class="flex justify-center pl-4">
    <div class="relative">
      <!-- glow -->
      <div
        class="absolute inset-0 rounded-full bg-foreground/10 blur-3xl scale-125 will-change-transform"
      >
      </div>

      <Image
        src={UserAvatar}
        width={320}
        height={320}
        alt="profile"
        class="relative h-[clamp(13rem,28vw,18rem)] w-auto rounded-full object-cover border border-foreground/10 hover:scale-[1.03] will-change-transform transition-all duration-300 ease-out"
      />
    </div>
  </div>

  <div class="pl-8 pr-8 mt-4 md:mt-1">
    <h1
      class="text-[clamp(2rem,3vw,3rem)] font-semibold tracking-tight text-foreground"
    >
      <span class="text-foreground/40 mr-3">$</span>
      whoami
    </h1>

    <h2
      class="mt-6 mb-4 text-[12px] md:text-sm uppercase tracking-[0.2em] text-foreground/40"
    >
      # user.info
    </h2>

    <p
      class="max-w-2xl text-[1rem] md:text-[1.10rem] leading-8 text-foreground/75"
    >
      hey, my name’s <span
        class="dark:drop-shadow-[0_0_10px_rgba(255,255,255,0.4)] drop-shadow-[0_0_10px_rgba(0,0,0,0.2)] dark:text-zinc-100 text-zinc-900 underline decoration-2 underline-offset-3"
        >gourav</span
      >. i enjoy writing code in c, c++, go, and python. i’m mostly interested
      in systems programming, cpu architecture, networking, and building small
      tools that do one thing well.
    </p>
    <div class="mt-8 grid grid-cols-3 md:gap-6">
      <a
        href="https://github.com/c2-07"
        target="_blank"
        class="group border-l border-foreground/10 pl-4 py-2 rounded-r-lg
           text-foreground/70 hover:text-foreground
           dark:hover:bg-zinc-500/5 hover:bg-zinc-500/10
           dark:hover:drop-shadow-[0_0_12px_rgba(255,255,255,0.25)] hover:drop-shadow-[0_0_12px_rgba(0,0,0,0.25)]
           transition-all duration-300"
      >
        <span class="dark:drop-shadow-[0_0_8px_rgba(255,255,255,0.4)] drop-shadow-[0_0_8px_rgba(0,0,0,0.2)] dark:text-zinc-400 text-zinc-600"
          >$
        </span> github
      </a>

      <a
        href="https://www.linkedin.com/in/gouravjareda"
        target="_blank"
        class="group border-l border-foreground/10 pl-4 py-2 rounded-r-lg
           text-foreground/70 hover:text-foreground
           dark:hover:bg-blue-500/5 hover:bg-blue-500/10
           dark:hover:drop-shadow-[0_0_12px_rgba(59,130,246,0.35)] hover:drop-shadow-[0_0_12px_rgba(59,130,246,0.35)]
           transition-all duration-300"
      >
        <span class="dark:text-blue-400 text-blue-600">$ </span>linkedin
      </a>

      <a
        href="/pdfs/resume.pdf"
        target="_blank"
        class="group border-l border-foreground/10 pl-4 py-2 rounded-r-lg
           text-foreground/70 hover:text-foreground
           dark:hover:bg-emerald-600/5 hover:bg-emerald-600/10
           dark:hover:drop-shadow-[0_0_12px_rgba(52,211,153,0.35)] hover:drop-shadow-[0_0_12px_rgba(52,211,153,0.35)]
           transition-all duration-300"
      >
        <span class="dark:text-emerald-400 text-emerald-600">$ </span>resume
      </a>
    </div>
  </div>
</section>

<div
  class="mt-6 mb-14 h-px w-full dark:bg-[linear-gradient(90deg,transparent_0%,rgba(255,255,255,0.03)_15%,rgba(255,255,255,0.12)_50%,rgba(255,255,255,0.03)_85%,transparent_100%)] bg-[linear-gradient(90deg,transparent_0%,rgba(0,0,0,0.03)_15%,rgba(0,0,0,0.12)_50%,rgba(0,0,0,0.03)_85%,transparent_100%)]"
>
</div>
