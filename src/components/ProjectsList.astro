---
export type project = {
  name: string;
  description: string;
  tags: string[];
  year: number;
  status: "completed" | "active" | "archived";
  link: string;
};

export const projects: project[] = [
  {
    name: "subdog",
    description:
      "high-concurrency subdomain brute-forcer with async dns resolution, wildcard detection, and resolver rotation.",
    tags: ["python", "dns", "networking"],
    year: 2026,
    status: "active",
    link: "https://github.com/example/subdog",
  },
  {
    name: "postoffice",
    description:
      "minimal file sharing platform built with fastapi, sqlmodel, and sqlite.",
    tags: ["python", "fastapi", "backend"],
    year: 2026,
    status: "active",
    link: "https://github.com/example/postoffice",
  },
  {
    name: "transferthing",
    description:
      "procedural json tokenizer and file reader written in c without external dependencies.",
    tags: ["c", "parser", "systems"],
    year: 2025,
    status: "completed",
    link: "https://github.com/example/transferthing",
  },
  {
    name: "wss",
    description:
      "tiny websocket library in c with tls support and a minimal event-driven api.",
    tags: ["c", "websocket", "networking"],
    year: 2026,
    status: "active",
    link: "https://github.com/example/wss",
  },
];

const last = projects.length - 1;
---

<main class="mx-auto max-w-3xl px-6 text-foreground/80 flex-1">
  <section class="space-y-12">
    <header>
      <h1 class="text-2xl font-bold text-foreground">
        <span class="text-muted">$ </span>
        cat ~/projects/readme.md
      </h1>

      <p class="max-w-[65ch] leading-8 text-foreground/70 mt-4">
        i enjoy building low-level tools, backend services, and networking
        software. these projects document what i’ve learned, what i’ve broken,
        and what i’ve rebuilt along the way.
      </p>
    </header>

    <div>
      <h2 class="text-2xl font-bold text-foreground mb-4">
        <span class="text-muted">$ </span>
        ls -lh ~/projects
      </h2>

      <span class="inline-block mb-1">projects</span>

      {
        projects.map((project, index) => (
          <div
            class={`group flex gap-2 border-l ${
              index !== last
                ? "pt-4 pb-10"
                : "border-b pb-4 border-b-muted mb-10"
            }`}
          >
            <span class="text-muted group-hover:text-sky-300 select-none">
              ───
            </span>

            <div>
              <div class="flex flex-col flex-wrap justify-center">
                <h3 class="mr-4 font-bold text-foreground/85 transition-all group-hover:text-foreground/90 group-hover:drop-shadow-[0_0_6px_rgba(255,255,255,0.5)]">
                  {project.name}
                </h3>

                <div class="mb-2 space-x-2">
                  {project.tags.map((tag) => (
                    <span class="rounded border border-muted/30 px-1.5 py-0.5 text-xs text-muted">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>

              <p class="mt-1 text-sm text-muted">{project.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</main>
