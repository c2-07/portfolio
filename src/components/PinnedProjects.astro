---
type Project = {
  name: string;
  description: string;
  tags: string[];
  link: string;
};

export const projects: Project[] = [
  {
    name: "transferThing",
    description: "cli-tool to share files over local network",
    tags: ["c", "python"],
    link: "https://github.com/c2-07/transferthing",
  },
  {
    name: "postOffice",
    description:
      "temporary file sharing service with direct uploads and downloads.",
    tags: ["fastapi", "sqlmodel", "sqlite"],
    link: "https://github.com/c2-07/postOffice",
  },
  {
    name: "wssThing",
    description: "minimal websocket library in c with tls support.",
    tags: ["c", "networking"],
    link: "",
  },
  {
    name: "subdog",
    description: "high-concurrency subdomain brute-forcer using async dns.",
    tags: ["python", "networking"],
    link: "",
  },
];
---

<section class="flex flex-col md:flex-row px-4 md:px-12 lg:px-16 gap-8">
  <div class="flex-1 space-y-8">
    <h1 class="text-foreground/95 text-lg font-semibold"># projects</h1>

    <div class="space-y-8">
      {
        projects.map((project) => (
          <a href={project.link} class="group block text-foreground">
            <div class="flex flex-wrap items-center gap-2">
              <span class="text-muted group-hover:text-accent">$</span>

              <span class="font-medium">{project.name}</span>

              {project.tags.map((tag) => (
                <span class="text-xs text-muted border border-muted/30 px-1.5 py-0.5 rounded">
                  {tag}
                </span>
              ))}
            </div>

            <p class="mt-2 pl-5 text-muted"> └─ {project.description}</p>
          </a>
        ))
      }
    </div>

    <a
      href="/projects"
      class="hover:underline text-foreground/80 transition-transform duration-300 text-sm ml-1.5"
      >view all projects ➔</a
    >
  </div>
  <div class="flex-1"></div>
</section>

<div
  class="mt-16 mb-14 h-px w-full bg-[linear-gradient(90deg,transparent_0%,rgba(255,255,255,0.03)_15%,rgba(255,255,255,0.12)_50%,rgba(255,255,255,0.03)_85%,transparent_100%)]"
>
</div>
