---
const users = [
  "thatmagicalcat",
  "duskyelf",
  "birbuh",
  "PranavU-Coder",
  "arithefirst",
];

const connections = await Promise.all(
  users.map(async (username) => {
    const res = await fetch(`https://api.github.com/users/${username}`);
    const user = await res.json();

    return {
      username: user.login,
      avatar: user.avatar_url,
      url: user.html_url,
    };
  }),
);
---

<section class="mx-16 mb-20">
  <h1 class="text-foreground/95 text-lg font-semibold"># connections</h1>

  <p class="text-muted mt-4">
    here are some of my&nbsp;
    <span class="border-b-2 border-foreground text-foreground cursor-pointer">
      cool friends
    </span>, do checkout their stuff
  </p>

  <div class="grid grid-cols-[repeat(6,96px)] auto-rows-[96px] gap-2 mt-4">
    {
      connections.map((friend) => (
        <a
          href={friend.url}
          target="_blank"
          class="overflow-hidden border border-border shadow-sm shadow-white/10 hover:scale-105 transition-transform duration-300 ease-out"
        >
          <div class="relative h-full">
            <div class="absolute inset-0 bg-foreground/10 blur-3xl scale-125" />

            <img
              src={friend.avatar}
              alt={friend.username}
              class="h-full w-full object-cover hover:scale-110 transition-transform duration-300 ease-out"
            />
          </div>
        </a>
      ))
    }
  </div>
</section>
