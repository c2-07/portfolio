---
import BaseLayout from "../../layouts/BaseLayout.astro";
import LogPostCard from "../../components/ui/LogPostCard.astro";
import TerminalHeading from "../../components/ui/TerminalHeading.astro";

import { getCollection } from "astro:content";

// INFO: getCollection => promise<Post[]> (async)
const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title="gourav | logs"
  description="My thoughts, tutorials, and articles on systems programming."
>
  <main class="group mx-auto mb-8 w-full flex-1 space-y-8 text-foreground/80">
    <TerminalHeading command="logs" size="text-2xl" />

    <div class="space-y-4">
      {
        posts.map((post) => {
          const date = new Date(post.data.pubDate).toLocaleDateString("en-US", {
            month: "long",
            day: "numeric",
            year: "numeric"
          });
          return (
            <LogPostCard
              name={post.data.title}
              description={post.data.description}
              date={date}
              tags={post.data.tags || []}
              link={`/logs/${post.id}`}
            />
          );
        })
      }
    </div>
  </main>
</BaseLayout>
